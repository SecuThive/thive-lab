# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── 사이트 URL ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://thivelab.com

# ── Google Analytics ──────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google AdSense (승인 후 주석 해제) ───────────────────────
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=xxxxxxxxxx   # 블로그 포스트 본문 하단
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=xxxxxxxxxx   # 블로그 목록 사이드바
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=xxxxxxxxxx      # 홈 HOT 상품 아래

# ── Google Search Console ─────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 쿠팡 파트너스 API ─────────────────────────────────────────
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key

# ── Upstash Redis (API 레이트 리밋) ──────────────────────────
# UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ── 재검증 시크릿 (ISR 캐시 무효화) ──────────────────────────
REVALIDATE_SECRET=your_revalidate_secret

# ── Admin ────────────────────────────────────────────────────
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
